# Genus OS — variables de entorno (frontend)

# demo = mocks E3–E6 (default) · real = Google Drive + Sheets vía BFF
NEXT_PUBLIC_GENUS_DATA_MODE=demo
GENUS_DATA_MODE=demo
GENUS_FALLBACK_TO_DEMO=true
GENUS_DRIVE_CACHE_TTL_SECONDS=600
GENUS_DRIVE_MAX_INDEX_DEPTH=4

# Planificación: sheets (legacy) | native (Postgres Genus OS)
# Preview: native (Neon branch aislada). Production: solo native tras cutover confirmado.
GENUS_PLANNING_SOURCE=sheets
NEXT_PUBLIC_GENUS_PLANNING_SOURCE=sheets

# Neon Postgres (Vercel Marketplace)
# Preview y Production DEBEN usar bases/ramas Neon SEPARADAS.
# Nunca reutilizar la DATABASE_URL de Preview en Production.
# DATABASE_URL=
# DATABASE_URL_UNPOOLED=
# POSTGRES_URL=

# ── Cutover Production (checklist) ──
# 1) Neon: rama/database Production distinta a Preview
# 2) Confirmar en /api/v1/env-check (Production): hasDatabaseUrl + hasDatabaseUrlUnpooled
# 3) Aplicar migraciones: cd frontend && npm run db:migrate  (o build con migrate-if)
# 4) Setear SOLO en Production:
#      GENUS_PLANNING_SOURCE=native
#      NEXT_PUBLIC_GENUS_PLANNING_SOURCE=native
# 5) Redeploy Production · NO promover Preview DB
#
# ── Rollback a Sheets (sin borrar datos Postgres) ──
# Setear en el Environment afectado:
#   GENUS_PLANNING_SOURCE=sheets
#   NEXT_PUBLIC_GENUS_PLANNING_SOURCE=sheets
# Redeploy. Los WorkItems en Postgres permanecen intactos.

# Google service account (server only — nunca NEXT_PUBLIC_)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── OBLIGATORIO (única carpeta requerida) ──
GOOGLE_DRIVE_GENUS_FOLDER_ID=

# ── Overrides opcionales (si el auto-descubrimiento no alcanza) ──
# GOOGLE_DRIVE_PRODUCCION_2026_FOLDER_ID=
# GOOGLE_DRIVE_ELABORACION_FOLDER_ID=
# GOOGLE_DRIVE_PCP_FOLDER_ID=
# GOOGLE_DRIVE_LOTES_FOLDER_ID=
# GOOGLE_DRIVE_PRODUCTOS_FOLDER_ID=
# GOOGLE_DRIVE_DESARROLLO_FOLDER_ID=

# ── Fast path: IDs fijos de Sheets críticos ──
# GOOGLE_SHEETS_ASIGNACION_LOTES_2026_ID=
# GOOGLE_SHEETS_SEMANAS_2026_ID=
#
# PEDIDOS 2026 — debe ser Google Sheets nativo (no Office .xlsx).
# La Sheets API no lee .xlsx; si el archivo es Excel, convertir en Drive:
# Archivo → Guardar como Google Sheets (mismo nombre, pestañas, fórmulas, Dashboard).
# Luego actualizar GOOGLE_SHEETS_PEDIDOS_2026_ID y revalidar pestañas PEDIDOS/DASHBOARD.
# GOOGLE_SHEETS_PEDIDOS_2026_ID=

# ── Pestañas opcionales ──
# SHEETS_TAB_ASIGNACION_LOTES=ASIGNACION
# SHEETS_TAB_PEDIDOS=PEDIDOS

# ── Fase 3 convergencia OS (Strangler Fig — default desactivado) ──
# NEXT_PUBLIC_GENUS_OS_LEGACY_BANNER=true
# GENUS_OS_LEGACY_REDIRECTS=true

# ── DEPRECATED (E7) ──
# GOOGLE_SHEETS_SPREADSHEET_ID=
