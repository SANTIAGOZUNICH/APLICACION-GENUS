# Genus OS — variables de entorno (frontend)

# demo = mocks E3–E6 (default) · real = Google Sheets vía BFF
NEXT_PUBLIC_GENUS_DATA_MODE=demo
GENUS_DATA_MODE=demo
GENUS_FALLBACK_TO_DEMO=true

# Google Sheets (solo server — nunca usar NEXT_PUBLIC_ para credenciales)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Alternativa: ruta al JSON de service account
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Nombres de pestañas (defaults del modelo Genus)
SHEETS_TAB_LOTES=LOTES
SHEETS_TAB_SALDOS=SALDOS
SHEETS_TAB_MOVIMIENTOS=MOVIMIENTOS
