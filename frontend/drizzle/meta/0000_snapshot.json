      "checkConstraints": {
        "work_items_branch_owner_values": {
          "name": "work_items_branch_owner_values",
          "value": "\"work_items\".\"branch_owner\" IS NULL OR \"work_items\".\"branch_owner\" IN ('Cristian', 'Nicolás')"
        },
        "work_items_line_values": {
          "name": "work_items_line_values",
          "value": "\"work_items\".\"line\" IS NULL OR \"work_items\".\"line\" IN ('Línea 1', 'Línea 2', 'Línea 3', 'Línea 4')"
        },
        "work_items_sector_assignment": {
          "name": "work_items_sector_assignment",
          "value": "(\n        (\"work_items\".\"sector\" = 'ELABORACION' AND \"work_items\".\"line\" IS NULL AND \"work_items\".\"branch_owner\" IS NOT NULL)\n        OR (\"work_items\".\"sector\" = 'ENVASADO_MASIVO' AND \"work_items\".\"branch_owner\" IS NULL AND \"work_items\".\"line\" IN ('Línea 1', 'Línea 2', 'Línea 3', 'Línea 4'))\n        OR (\"work_items\".\"sector\" = 'ENVASADO_PREMIUM' AND \"work_items\".\"branch_owner\" IS NULL AND \"work_items\".\"line\" IN ('Línea 1', 'Línea 2'))\n      )"
        }
      },
